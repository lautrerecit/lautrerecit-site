---
// Curseur custom « anneau qui s'ouvre » (effet 03) — homogène avec le tunnel.
// Point doré net + anneau souple qui s'agrandit/se teinte au survol des éléments interactifs.
---
<div class="lrcur" aria-hidden="true"><span class="lrcur-ring"></span><span class="lrcur-dot"></span></div>

<style>
  .lrcur-dot, .lrcur-ring {
    position: fixed; top: 0; left: 0; z-index: 9999; pointer-events: none;
    border-radius: 50%; transform: translate(-50%, -50%); will-change: left, top;
  }
  .lrcur-dot { width: 7px; height: 7px; background: var(--or2); box-shadow: 0 0 10px rgba(196,162,74,.7); transition: opacity .2s, width .2s, height .2s; }
  .lrcur-ring { width: 32px; height: 32px; border: 1.5px solid rgba(196,162,74,.5); transition: width .3s, height .3s, border-color .3s, background .3s, opacity .25s; }
  :global(html.lrcur-hover) .lrcur-ring { width: 60px; height: 60px; border-color: var(--or3); background: rgba(196,162,74,.08); }
  :global(html.lrcur-hover) .lrcur-dot { opacity: 0; }
  :global(html.lrcur-down) .lrcur-ring { width: 46px; height: 46px; border-color: var(--or2); }

  /* masqué par défaut ; affiché seulement si souris fine + JS actif */
  .lrcur { display: none; }
  @media (pointer: fine) { :global(html.lrcur-on) .lrcur { display: block; } }
  @media (pointer: fine) { :global(html.lrcur-on), :global(html.lrcur-on *) { cursor: none !important; } }
  @media (prefers-reduced-motion: reduce) { .lrcur { display: none !important; } }
</style>

<script is:inline>
  (function () {
    if (!window.matchMedia || !matchMedia('(pointer: fine)').matches) return;
    if (matchMedia('(prefers-reduced-motion: reduce)').matches) return;
    var dot = document.querySelector('.lrcur-dot'), ring = document.querySelector('.lrcur-ring');
    if (!dot || !ring) return;
    var html = document.documentElement;
    var mx = innerWidth / 2, my = innerHeight / 2, rx = mx, ry = my;
    html.classList.add('lrcur-on');
    addEventListener('mousemove', function (e) { mx = e.clientX; my = e.clientY; }, { passive: true });
    addEventListener('mousedown', function () { html.classList.add('lrcur-down'); }, { passive: true });
    addEventListener('mouseup', function () { html.classList.remove('lrcur-down'); }, { passive: true });
    (function loop () {
      rx += (mx - rx) * .2; ry += (my - ry) * .2;
      dot.style.left = mx + 'px'; dot.style.top = my + 'px';
      ring.style.left = rx + 'px'; ring.style.top = ry + 'px';
      requestAnimationFrame(loop);
    })();
    var HOV = 'a,button,.btn,input,textarea,select,summary,[role=button],.cite-card,.insta-card,.feat,.g-card,.ap-card,.ap-jump';
    addEventListener('mouseover', function (e) { if (e.target.closest && e.target.closest(HOV)) html.classList.add('lrcur-hover'); });
    addEventListener('mouseout', function (e) { if (e.target.closest && e.target.closest(HOV)) html.classList.remove('lrcur-hover'); });
  })();
</script>
