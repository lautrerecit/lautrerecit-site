---
const { pathname } = Astro.url;
const isActive = (href) => pathname === href || (href !== '/' && pathname.startsWith(href));
const nav = [
  { href: '/', label: 'Accueil' },
  { href: '/a-propos/', label: 'À propos', children: [
    { href: '/vision/', label: 'La vision' },
    { href: '/grille-de-lecture/', label: 'La grille de lecture' },
    { href: '/architecture/', label: "L'architecture" },
  ] },
  { href: '/formations/', label: 'Formations' },
  { href: '/articles/', label: 'Articles' },
  { href: '/contact/', label: 'Contact' },
];
const TUNNEL = '/formation-nationalisme-noir/index.html'; // ⏳ BROUILLON Algérie : CTA header temporairement sur NNA. Repasser sur '/algerie/index.html' au lancement (dim. soir).
const SYSTEME_LOGIN = 'https://systeme.io/login'; // TODO: remplacer par l'URL de l'espace membre Systeme.io
---
<!-- Menu 08 · Encadré filet or (double filet doré, verre sombre) + CTA -->
<div class="lr-header-wrap">
  <header class="lr-header">
    <a class="lr-wordmark" href="/">L'Autre&nbsp;Récit</a>
    <nav class="lr-nav" aria-label="Navigation principale">
      {nav.map((n) =>
        n.children ? (
          <div class="lr-has-sub">
            <a href={n.href} class:list={['lr-link', 'lr-link-sub', { active: isActive(n.href) }]}>{n.label}<span class="lr-caret" aria-hidden="true">▾</span></a>
            <div class="lr-sub">
              {n.children.map((c) => (
                <a href={c.href} class:list={['lr-sublink', { active: isActive(c.href) }]}>{c.label}</a>
              ))}
            </div>
          </div>
        ) : n.external ? (
          <a href={n.href} class="lr-link" target="_blank" rel="noopener">{n.label}<span class="ext">↗</span></a>
        ) : (
          <a href={n.href} class:list={['lr-link', { active: isActive(n.href) }]}>{n.label}</a>
        )
      )}
    </nav>
    <div class="lr-actions">
      <a class="btn btn-oc lr-navbtn lr-navbtn-2nd" href={SYSTEME_LOGIN} target="_blank" rel="noopener">Se connecter</a>
      <a class="btn btn-or lr-navbtn" href={TUNNEL}><span class="lr-cta-full">Découvrir la formation</span><span class="lr-cta-short">La formation</span> <span class="ar">→</span></a>
    </div>
  </header>
</div>

<style>
  .lr-header-wrap {
    position: fixed; top: 12px; left: 0; right: 0; z-index: 60;
    padding-inline: var(--gutter);
    margin-inline: auto; max-width: var(--maxw); width: 100%;
    pointer-events: none;
  }
  .lr-header { pointer-events: auto; }
  /* Design 08 « Encadré filet or » — DOUBLE FILET doré (haut + bas), verre sombre */
  .lr-header {
    display: flex; align-items: center; gap: 22px;
    height: 58px; padding: 0 14px 0 26px;
    background: rgba(14,12,10,.82);
    backdrop-filter: blur(8px) saturate(130%);
    -webkit-backdrop-filter: blur(8px) saturate(130%);
    will-change: transform; transform: translateZ(0);
    border-top: 1.5px solid; border-bottom: 1.5px solid;
    border-left: 0; border-right: 0;
    border-image: linear-gradient(90deg, transparent, var(--or2) 16%, var(--or3) 50%, var(--or2) 84%, transparent) 1;
    box-shadow: 0 18px 44px -26px rgba(0,0,0,.6);
  }
  .lr-wordmark {
    font-family: var(--serif); font-weight: 700; font-style: italic;
    font-size: 21px; color: #fff; letter-spacing: -0.01em; white-space: nowrap;
    transition: color .25s;
  }
  .lr-wordmark:hover { color: var(--or3); }
  .lr-nav { display: flex; align-items: center; gap: clamp(14px, 2.4vw, 28px); margin-left: auto; }
  .lr-link {
    font-family: var(--sans); font-size: 15px; font-weight: 500;
    color: rgba(255,255,255,.74); white-space: nowrap;
    padding-block: 6px; position: relative; transition: color .25s;
  }
  .lr-link:hover { color: #fff; }
  .lr-link.active { color: var(--or2); font-weight: 600; }
  .lr-link .ext { font-size: 0.78em; margin-left: 3px; opacity: .65; }

  /* ===== Dropdown « À propos » ===== */
  .lr-has-sub { position: relative; display: flex; align-items: center; }
  .lr-link-sub { display: inline-flex; align-items: center; gap: 5px; }
  .lr-caret { font-size: 9px; opacity: .6; transition: transform .25s; }
  .lr-has-sub:hover .lr-caret, .lr-has-sub:focus-within .lr-caret { transform: rotate(180deg); }
  .lr-has-sub::after { content: ""; position: absolute; top: 100%; left: 0; right: 0; height: 16px; }
  .lr-sub {
    position: absolute; top: calc(100% + 12px); left: 50%;
    display: flex; flex-direction: column; min-width: 224px; padding: 8px;
    background: rgba(14,12,10,.96); backdrop-filter: blur(14px) saturate(140%); -webkit-backdrop-filter: blur(14px) saturate(140%);
    border: 1px solid; border-image: linear-gradient(120deg, rgba(196,162,74,.3), rgba(212,176,90,.6), rgba(196,162,74,.3)) 1;
    border-radius: 10px; box-shadow: 0 24px 50px -20px rgba(0,0,0,.7);
    opacity: 0; visibility: hidden; pointer-events: none; transform: translateX(-50%) translateY(6px);
    transition: opacity .25s, transform .25s, visibility .25s;
  }
  .lr-has-sub:hover .lr-sub, .lr-has-sub:focus-within .lr-sub { opacity: 1; visibility: visible; pointer-events: auto; transform: translateX(-50%) translateY(0); }
  .lr-sublink { font-family: var(--sans); font-size: 14px; font-weight: 500; color: rgba(255,255,255,.78); padding: 10px 14px; border-radius: 7px; white-space: nowrap; transition: background .2s, color .2s; }
  .lr-sublink:hover { background: rgba(196,162,74,.12); color: #fff; }
  .lr-sublink.active { color: var(--or2); }

  /* actions : Se connecter (B · or contour) + Découvrir la formation (A · or plein) */
  /* → vrais boutons du design system (.btn .btn-or / .btn .btn-oc de global.css), taille « nav » */
  .lr-actions { display: flex; align-items: center; gap: 12px; flex-shrink: 0; }
  .lr-navbtn { padding: 11px 20px; font-size: 12px; letter-spacing: 0.1em; white-space: nowrap; }
  .lr-cta-short { display: none; }

  @media (max-width: 860px) {
    .lr-header { padding: 0 10px 0 16px; gap: 12px; }
    .lr-wordmark { font-size: 18px; }
    .lr-nav { margin-left: 0; flex: 1; min-width: 0; gap: 16px; overflow-x: auto; scrollbar-width: none; -webkit-overflow-scrolling: touch; }
    .lr-nav::-webkit-scrollbar { display: none; }
    .lr-link { font-size: 13.5px; }
    .lr-navbtn-2nd { display: none; }          /* « Se connecter » masqué sur mobile */
    .lr-sub, .lr-caret { display: none; }      /* dropdown désactivé sur mobile → À propos ouvre la page */
    .lr-navbtn { padding: 13px 15px; font-size: 11px; letter-spacing: 0.06em; }
  }
  @media (max-width: 560px) {
    .lr-cta-full { display: none; }
    .lr-cta-short { display: inline; }
  }
</style>
