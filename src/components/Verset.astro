---
// Signature spirituelle du site — bande horizontale compacte, affichée en bas de CHAQUE page (avant le footer).
// Désactivable page par page via la prop `noVerset` du layout Base.
---
<section class="verset">
  <div class="container verset-in">
    <p class="verset-kicker">Notre boussole</p>
    <p class="verset-ar" lang="ar" dir="rtl">إِنَّ اللَّهَ لَا يُغَيِّرُ مَا بِقَوْمٍ حَتَّىٰ يُغَيِّرُوا مَا بِأَنْفُسِهِمْ</p>
    <p class="verset-fr">«&nbsp;<b class="vk">Allah ne modifie pas l'état d'un peuple</b> tant que <b class="vk">les individus</b> qui le composent <b class="vk">ne modifient pas</b> <b class="vk">ce</b> qui est <b class="vk">en eux-mêmes</b>.&nbsp;»</p>
    <p class="verset-ref">Sourate Ar-Ra'd · 13 · 11</p>
  </div>
</section>

<style>
  /* bande compacte, centrée, encadrée de deux filets dorés */
  .verset {
    position: relative; text-align: center; overflow: hidden;
    background: radial-gradient(120% 120% at 50% 50%, #16110B 0%, #0E0C0A 70%, #0A0807 100%);
    color: var(--cr);
    padding-block: clamp(44px, 6vw, 72px);
    border-top: 1px solid; border-bottom: 1px solid;
    border-image: linear-gradient(90deg, transparent, rgba(196,162,74,.45) 28%, rgba(212,176,90,.6) 50%, rgba(196,162,74,.45) 72%, transparent) 1;
  }
  .verset::before { content: ""; position: absolute; left: 50%; top: 50%; width: 620px; height: 280px; transform: translate(-50%,-50%); background: radial-gradient(circle, rgba(196,162,74,.07), transparent 68%); pointer-events: none; }
  .verset-in { position: relative; z-index: 1; }
  /* max-width:none → on neutralise le max-width:68ch global des <p> pour un vrai centrage */
  .verset-kicker { font-family: var(--mono); font-size: 10.5px; font-weight: 700; letter-spacing: 0.3em; text-transform: uppercase; color: var(--or3); margin: 0 auto 18px; max-width: none; }
  .verset-ar { font-family: 'Amiri', 'Times New Roman', serif; font-weight: 400; font-size: clamp(22px, 3.1vw, 37px); line-height: 1.5; color: #F6F1E8; margin: 0 auto; max-width: 92%; direction: rtl; text-shadow: 0 0 30px rgba(255,255,255,.10); }
  .verset-fr { font-family: var(--serif); font-style: normal; font-weight: 400; font-size: clamp(15px, 1.65vw, 20px); line-height: 1.5; color: rgba(242,237,228,.88); max-width: 56ch; margin: 16px auto 0; }
  .verset-fr em { font-style: italic; color: transparent; background: var(--gold); -webkit-background-clip: text; background-clip: text; }
  /* mots-clés du verset : doré métallique GRAS (non italique) */
  .verset-fr .vk { font-weight: 700; font-style: italic; color: transparent; background: var(--gold); -webkit-background-clip: text; background-clip: text; }
  .verset-ref { font-family: var(--mono); font-size: 10.5px; font-weight: 700; letter-spacing: 0.22em; text-transform: uppercase; color: var(--or2); margin: 18px auto 0; max-width: none; }
</style>
