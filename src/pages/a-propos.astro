---
import Base from '../layouts/Base.astro';

// ============================================================
// À PROPOS — hub premium. Hero sombre, puis 3 sections qui ALTERNENT
// sombre/crème, une par sous-page (Vision · Grille · Architecture).
// Cards adaptées au fond (sombre sur crème, clair sur sombre). Fonds explicites (bulletproof).
// ============================================================
const concepts = ['Colonisabilité', 'Hégémonie', 'Aliénation', 'Récit', 'Civilisation', 'Transmission'];
---
<Base
  title="À propos — L'Autre Récit"
  description="L'Autre Récit, média d'analyse critique né en 2023 : la vision, la grille de lecture et l'architecture. D'où l'on parle, avec quels outils, et pourquoi."
>
  <div class="ab-page">
    <!-- ===== HERO (sombre) ===== -->
    <section class="ab-hero ab-dark">
      <div class="grain"></div>
      <div class="container">
        <p class="ab-eyebrow">À propos</p>
        <h1 class="ab-h1">Qui parle, et <span class="gold-grad">d'où</span>&nbsp;?</h1>
        <p class="ab-lede">L'Autre Récit, un média d'analyse critique. Une double grille&nbsp;: la science politique et la pensée islamique.</p>
        <span class="ab-scroll" aria-hidden="true"></span>
      </div>
    </section>

    <!-- ===== 01 · VISION (crème) ===== -->
    <section class="ab-band ab-cream">
      <div class="container ab-row">
        <div class="ab-tx reveal">
          <span class="ab-num">01</span>
          <p class="ab-eye">La vision</p>
          <h2 class="ab-h2">Une lettre du <span class="gold-grad">fondateur</span>.</h2>
          <p class="ab-d">D'où vient ce média, qui le porte, et ce qui le tient. Né en 2023 d'une conviction simple, porté par un fondateur formé à la science politique.</p>
          <a class="btn btn-or ab-cta" href="/vision/">Lire la vision <span class="ar">→</span></a>
        </div>
        <div class="ab-viz reveal">
          <figure class="ab-quote ab-on-cream">
            <span class="ab-quote-mark" aria-hidden="true">«</span>
            <blockquote>Comment, en tant que minorités, faire face à nos problématiques sociales et politiques sans les comprendre&nbsp;?</blockquote>
            <figcaption>— Rany, fondateur</figcaption>
          </figure>
        </div>
      </div>
    </section>

    <!-- ===== 02 · GRILLE DE LECTURE (sombre) ===== -->
    <section class="ab-band ab-dark">
      <div class="grain"></div>
      <div class="container ab-row ab-row-rev">
        <div class="ab-tx reveal">
          <span class="ab-num">02</span>
          <p class="ab-eye">La grille de lecture</p>
          <h2 class="ab-h2">Des outils pour <span class="gold-grad">lire le monde</span>.</h2>
          <p class="ab-d">Des concepts mobilisés comme grille d'analyse — la colonisabilité, l'hégémonie, l'aliénation… Une base de travail, jamais une liste fermée.</p>
          <a class="btn btn-or ab-cta" href="/grille-de-lecture/">Voir la grille <span class="ar">→</span></a>
        </div>
        <div class="ab-viz reveal">
          <ul class="ab-chips" aria-label="Des concepts-outils">
            {concepts.map((c) => <li class="ab-chip">{c}</li>)}
            <li class="ab-chip ab-chip-more">… et d'autres</li>
          </ul>
        </div>
      </div>
    </section>

    <!-- ===== 03 · ARCHITECTURE (crème) ===== -->
    <section class="ab-band ab-cream">
      <div class="container ab-row">
        <div class="ab-tx reveal">
          <span class="ab-num">03</span>
          <p class="ab-eye">L'architecture</p>
          <h2 class="ab-h2">Le socle&nbsp;: <span class="gold-grad">l'islam</span>.</h2>
          <p class="ab-d">D'où part l'analyse, et pourquoi ce point de départ change ce qu'on voit. Le refus de la fausse neutralité, et la boussole qui oriente.</p>
          <a class="btn btn-or ab-cta" href="/architecture/">Lire l'architecture <span class="ar">→</span></a>
        </div>
        <div class="ab-viz reveal">
          <figure class="ab-verse ab-on-cream">
            <p class="ab-verse-label">La boussole</p>
            <p class="ab-verse-fr">«&nbsp;Allah ne modifie pas l'état d'<em>un peuple</em> tant que les individus qui le composent ne modifient pas ce qui est <em>en eux-mêmes</em>.&nbsp;»</p>
            <figcaption>Sourate Ar-Ra'd · 13 · 11</figcaption>
          </figure>
        </div>
      </div>
    </section>
  </div>
</Base>

<style>
  .ab-page { color: var(--ink2); }

  /* fonds EXPLICITES (bulletproof) */
  .ab-dark { position: relative; overflow: hidden; background-color: #0C0A07; background-image: radial-gradient(130% 80% at 50% 0%, #1A1714 0%, #0E0C0A 52%, #0A0807 100%); color: var(--cr); }
  .ab-cream { background-color: var(--cr); color: var(--ink2); }
  .ab-dark .grain { position: absolute; inset: 0; pointer-events: none; opacity: .05; z-index: 0; background-image: url("data:image/svg+xml,%3Csvg viewBox='0 0 256 256' xmlns='http://www.w3.org/2000/svg'%3E%3Cfilter id='n'%3E%3CfeTurbulence type='fractalNoise' baseFrequency='.85' numOctaves='4' stitchTiles='stitch'/%3E%3C/filter%3E%3Crect width='100%25' height='100%25' filter='url(%23n)'/%3E%3C/svg%3E"); }
  .ab-dark .container { position: relative; z-index: 1; }

  .reveal { opacity: 0; transform: translateY(22px); transition: opacity .7s var(--ease), transform .7s var(--ease); }
  .reveal.in { opacity: 1; transform: none; }

  /* ===== HERO ===== */
  .ab-hero { text-align: center; padding-block: clamp(80px, 12vw, 144px) clamp(40px, 6vw, 64px); }
  .ab-eyebrow { font-family: var(--mono); font-size: 12px; font-weight: 700; letter-spacing: 0.28em; text-transform: uppercase; color: var(--or3); margin: 0 0 14px; }
  .ab-h1 { font-family: var(--serif); font-weight: 700; font-size: clamp(46px, 7.6vw, 98px); line-height: .95; letter-spacing: -0.03em; color: #fff; margin: 0; }
  .ab-h1 .gold-grad { font-style: italic; }
  .ab-lede { max-width: 56ch; margin: 24px auto 0; font-weight: 300; font-size: clamp(16px, 1.7vw, 19.5px); line-height: 1.62; color: rgba(242,237,228,.8); }
  .ab-scroll { display: block; width: 1px; height: clamp(34px, 5vw, 54px); margin: clamp(28px, 4vw, 44px) auto 0; background: linear-gradient(180deg, var(--or2), transparent); }

  /* ===== BANDES (sections) ===== */
  .ab-band { padding-block: clamp(56px, 8vw, 104px); }
  .ab-row { display: grid; grid-template-columns: 1.05fr .95fr; gap: clamp(32px, 5vw, 72px); align-items: center; }
  .ab-row-rev .ab-tx { order: 2; }
  @media (max-width: 820px) { .ab-row, .ab-row-rev { grid-template-columns: 1fr; gap: 32px; } .ab-row-rev .ab-tx { order: 0; } }

  .ab-num { font-family: var(--serif); font-style: italic; font-weight: 900; font-size: clamp(48px, 7vw, 84px); line-height: 1; color: transparent; background: var(--gold); -webkit-background-clip: text; background-clip: text; display: block; }
  .ab-eye { font-family: var(--mono); font-size: 11.5px; font-weight: 700; letter-spacing: 0.22em; text-transform: uppercase; color: var(--or2); margin: 12px 0 10px; }
  .ab-h2 { font-family: var(--serif); font-weight: 700; font-size: clamp(30px, 4vw, 52px); line-height: 1.08; letter-spacing: -0.025em; margin: 0; }
  .ab-cream .ab-h2 { color: var(--ink); }
  .ab-dark .ab-h2 { color: #fff; }
  .ab-h2 .gold-grad { font-style: italic; }
  .ab-d { font-family: var(--sans); font-weight: 300; font-size: clamp(16px, 1.6vw, 18.5px); line-height: 1.7; max-width: 46ch; margin: 18px 0 0; }
  .ab-cream .ab-d { color: var(--ink3); }
  .ab-dark .ab-d { color: rgba(242,237,228,.78); }
  .ab-cta { margin-top: 26px; }

  /* ===== VIZ : carte citation (sombre sur crème) ===== */
  .ab-quote { position: relative; margin: 0; padding: clamp(30px, 4vw, 46px) clamp(28px, 3.5vw, 42px); border-radius: 18px; }
  .ab-on-cream { background: linear-gradient(158deg, #1C160F 0%, #12100B 60%, #0C0A07 100%); border: 1px solid rgba(196,162,74,.4); border-top: 2px solid var(--or2); box-shadow: 0 40px 90px -44px rgba(14,12,10,.55); }
  .ab-quote-mark { font-family: var(--serif); font-style: italic; font-weight: 900; font-size: 64px; line-height: .4; height: .42em; display: block; color: transparent; background: var(--gold); -webkit-background-clip: text; background-clip: text; }
  .ab-quote blockquote { font-family: var(--serif); font-style: italic; font-weight: 400; font-size: clamp(20px, 2.3vw, 28px); line-height: 1.42; color: #fff; margin: 10px 0 0; }
  .ab-quote figcaption { margin: 22px 0 0; padding-top: 16px; border-top: 1px solid rgba(212,176,90,.22); font-family: var(--mono); font-size: 11px; font-weight: 700; letter-spacing: 0.16em; text-transform: uppercase; color: var(--or2); }

  /* ===== VIZ : chips penseurs (clair sur sombre) ===== */
  .ab-chips { list-style: none; margin: 0; padding: 0; display: flex; flex-wrap: wrap; gap: 12px; }
  .ab-chip { font-family: var(--serif); font-style: italic; font-weight: 700; font-size: clamp(17px, 1.9vw, 23px); color: var(--cr); padding: 12px 22px; border-radius: 100px; border: 1px solid rgba(212,176,90,.45); background: rgba(246,240,232,.04); transition: transform .35s var(--ease), border-color .35s, background .35s, color .35s; }
  .ab-chip:hover { transform: translateY(-3px); border-color: var(--or2); background: rgba(196,162,74,.14); color: #fff; }
  .ab-chip-more { border-style: dashed; border-color: rgba(212,176,90,.3); color: rgba(242,237,228,.55); font-weight: 400; }

  /* ===== VIZ : verset (sombre sur crème) ===== */
  .ab-verse { position: relative; margin: 0; text-align: center; padding: clamp(34px, 4.5vw, 52px) clamp(24px, 3.5vw, 40px); border-radius: 18px; overflow: hidden; }
  .ab-verse::before { content: ""; position: absolute; left: 50%; top: 50%; width: 80%; height: 60%; transform: translate(-50%,-50%); background: radial-gradient(circle, rgba(196,162,74,.12), transparent 70%); pointer-events: none; }
  .ab-verse-label { position: relative; font-family: var(--mono); font-size: 10.5px; font-weight: 700; letter-spacing: 0.3em; text-transform: uppercase; color: var(--or3); margin: 0 0 18px; }
  .ab-verse-ar { position: relative; font-family: 'Amiri', serif; font-weight: 400; font-size: clamp(22px, 2.8vw, 34px); line-height: 1.7; color: #F8F3E9; direction: rtl; margin: 0; text-shadow: 0 0 30px rgba(255,255,255,.1); }
  .ab-verse-fr { position: relative; font-family: var(--serif); font-style: normal; font-weight: 400; font-size: clamp(17px, 1.9vw, 22px); line-height: 1.5; color: rgba(242,237,228,.92); max-width: 30ch; margin: 0 auto; }
  .ab-verse-fr em { font-style: italic; color: transparent; background: var(--gold); -webkit-background-clip: text; background-clip: text; }
  .ab-verse figcaption { position: relative; font-family: var(--mono); font-size: 10.5px; font-weight: 700; letter-spacing: 0.22em; text-transform: uppercase; color: var(--or2); margin: 20px 0 0; }

  @media (prefers-reduced-motion: reduce) { .reveal { opacity: 1; transform: none; transition: none; } }
</style>

<script is:inline>
  (function () {
    var obs = new IntersectionObserver(function (entries) {
      entries.forEach(function (e) { if (e.isIntersecting) { e.target.classList.add('in'); obs.unobserve(e.target); } });
    }, { threshold: 0.16 });
    document.querySelectorAll('.ab-page .reveal').forEach(function (el) { obs.observe(el); });
  })();
</script>
