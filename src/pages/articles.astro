---
import Base from '../layouts/Base.astro';
import { articles, SUB } from '../data/articles.js';
---
<Base
  title="Le journal — Articles | L'Autre Récit"
  description="Les analyses au long cours de L'Autre Récit, publiées sur Substack : histoire, médias, géopolitique, spiritualité — lues avec une grille de science politique."
>
  <!-- ===== HERO ===== -->
  <div class="aj-top">
    <div class="grain"></div>
    <section class="aj-hero">
      <div class="container">
        <p class="eyebrow">Le journal</p>
        <h1 class="aj-h1">Les <em class="gold-grad">articles</em></h1>
        <p class="aj-lede">Les analyses au long cours de L'Autre Récit, publiées sur Substack. Colonisation et décolonisation, géopolitique, conflit, société — lues avec les outils de la science politique et de la pensée islamique.</p>
      </div>
    </section>
  </div>

  <!-- ===== GRILLE COMPLÈTE (feuilleton portrait, N&B) ===== -->
  <section class="artf">
    <div class="artf-list">
      {articles.map((a) => (
        <a class="artf-band reveal" href={a.url} target="_blank" rel="noopener" aria-label={a.t}>
          <div class="artf-ph"><img src={a.cover} alt={a.t} loading="lazy" /></div>
          <div class="artf-tx">
            <div class="artf-meta">{a.cat} · {a.date}</div>
            <h2 class="artf-bh">{a.t}</h2>
            <p class="artf-d">{a.d}</p>
            <span class="artf-lk"><i></i><b>Lire sur Substack</b></span>
          </div>
        </a>
      ))}
    </div>
    <div class="artf-cta">
      <a class="btn btn-or" href={SUB} target="_blank" rel="noopener">Tout lire sur Substack <span class="ar">→</span></a>
    </div>
  </section>
</Base>

<style>
  /* ===== HERO ===== */
  .aj-top { position: relative; background: radial-gradient(120% 90% at 50% -10%, #1A1714 0%, #0E0C0A 55%, #0A0807 100%); color: #fff; overflow: hidden; }
  .aj-top .grain { position: absolute; inset: 0; pointer-events: none; opacity: .05; background-image: url("data:image/svg+xml,%3Csvg viewBox='0 0 256 256' xmlns='http://www.w3.org/2000/svg'%3E%3Cfilter id='n'%3E%3CfeTurbulence type='fractalNoise' baseFrequency='.85' numOctaves='4' stitchTiles='stitch'/%3E%3C/filter%3E%3Crect width='100%25' height='100%25' filter='url(%23n)'/%3E%3C/svg%3E"); }
  .aj-hero { position: relative; z-index: 1; padding-block: clamp(92px, 12vw, 140px) clamp(34px, 5vw, 56px); text-align: center; }
  .aj-hero .eyebrow { color: var(--or3); }
  .aj-h1 { font-family: var(--serif); font-weight: 700; color: #fff; font-size: clamp(40px, 6.4vw, 86px); line-height: .98; letter-spacing: -0.03em; margin: 14px 0 0; }
  .aj-h1 em { font-style: italic; }
  .aj-lede { font-size: clamp(17px, 1.8vw, 21px); color: rgba(255,255,255,.78); line-height: 1.6; max-width: 58ch; margin: 20px auto 0; font-weight: 300; }

  /* ===== GRILLE — feuilleton portrait, photos N&B alternées ===== */
  .artf { background: radial-gradient(120% 60% at 50% 0%, #15110C 0%, #0E0C0A 50%, #0A0807 100%); padding-bottom: clamp(56px, 8vw, 100px); }
  .artf-list { }
  .artf-band { position: relative; display: grid; grid-template-columns: 1.15fr .85fr; align-items: center; min-height: 470px; padding: 24px 0; text-decoration: none; color: var(--cr); }
  .artf-band:nth-child(even) { grid-template-columns: .85fr 1.15fr; }
  .artf-band:nth-child(even) .artf-ph { order: 2; }
  /* PHOTO — hauteur fixe = uniformité */
  .artf-ph { position: relative; height: 400px; margin-inline: clamp(18px, 4vw, 40px); border-radius: 14px; overflow: hidden; border: 1px solid rgba(212,176,90,.18); }
  .artf-ph img { width: 100%; height: 100%; object-fit: cover; display: block; filter: grayscale(1) brightness(.86) contrast(1.06); transition: transform 1s cubic-bezier(.22,1,.36,1), filter .8s; }
  .artf-band:hover .artf-ph img { transform: scale(1.05); filter: grayscale(1) brightness(1) contrast(1.06); }
  /* PANNEAU flottant — taille fixe = uniformité, chevauche la photo */
  .artf-tx { position: relative; z-index: 2; min-height: 300px; display: flex; flex-direction: column; justify-content: center; background: linear-gradient(158deg, #1C160F 0%, #12100B 60%, #0C0A07 100%); border: 1px solid rgba(212,176,90,.34); border-top: 2px solid var(--or2); border-radius: 14px; padding: clamp(28px, 3vw, 40px); box-shadow: 0 44px 90px -44px #000; }
  .artf-band:nth-child(odd) .artf-tx { margin-left: clamp(-96px, -7vw, -44px); }
  .artf-band:nth-child(even) .artf-tx { margin-right: clamp(-96px, -7vw, -44px); }
  .artf-meta { font-family: var(--mono); font-size: 10.5px; font-weight: 700; letter-spacing: 0.16em; text-transform: uppercase; color: var(--or2); margin-bottom: 14px; }
  .artf-bh { font-family: var(--serif); font-weight: 700; font-size: clamp(21px, 2.2vw, 31px); line-height: 1.14; letter-spacing: -0.015em; color: #fff; margin: 0 0 12px; }
  .artf-d { font-family: var(--sans); font-weight: 300; font-size: clamp(14.5px, 1.4vw, 17px); line-height: 1.55; color: rgba(242,237,228,.74); margin: 0 0 20px; }
  .artf-lk { display: inline-flex; align-items: center; gap: 11px; font-family: var(--mono); font-size: 11px; font-weight: 700; letter-spacing: 0.16em; text-transform: uppercase; color: var(--cr); }
  .artf-lk i { display: inline-block; width: 26px; height: 1px; background: var(--or2); transition: width .35s cubic-bezier(.22,1,.36,1); }
  .artf-band:hover .artf-lk i { width: 48px; }
  .artf-lk b { color: var(--or3); font-weight: 700; }
  .artf-cta { text-align: center; margin-top: clamp(44px, 6vw, 64px); }

  /* reveal */
  .reveal { opacity: 0; transform: translateY(22px); transition: opacity .7s cubic-bezier(.22,1,.36,1), transform .7s cubic-bezier(.22,1,.36,1); }
  .reveal.in { opacity: 1; transform: none; }

  @media (prefers-reduced-motion: reduce) { .reveal { opacity: 1; transform: none; transition: none; } }
  @media (max-width: 820px) {
    .artf-band, .artf-band:nth-child(even) { grid-template-columns: 1fr; padding: 0 0 14px; min-height: 0; }
    .artf-band:nth-child(even) .artf-ph { order: 0; }
    .artf-ph { height: 230px; margin-inline: 18px; }
    .artf-tx, .artf-band:nth-child(odd) .artf-tx, .artf-band:nth-child(even) .artf-tx { margin: -56px 18px 0; min-height: 0; }
  }
</style>

<script is:inline>
  (function () {
    var els = document.querySelectorAll('.reveal');
    if (!('IntersectionObserver' in window) || window.matchMedia('(prefers-reduced-motion: reduce)').matches) {
      els.forEach(function (el) { el.classList.add('in'); });
      return;
    }
    var obs = new IntersectionObserver(function (entries) {
      entries.forEach(function (e) { if (e.isIntersecting) { e.target.classList.add('in'); obs.unobserve(e.target); } });
    }, { threshold: 0.14 });
    els.forEach(function (el) { obs.observe(el); });
  })();
</script>
