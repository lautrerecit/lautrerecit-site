---
import Base from '../../layouts/Base.astro';

const TUNNEL = '/algerie/index.html'; // page de vente (pricing + checkout Stripe)

// Ce que vous saurez faire — 5 compétences (verbe d'action + mécanisme).
const competences = [
  { v: "Sortir", d: "Du roman des trois dates. Voir 1830-1962 comme une matrice continue — juridique, scolaire, foncière — bien plus vaste que la seule guerre d'indépendance." },
  { v: "Relire", d: "Ibn Khaldoun pour comprendre comment on défait une société. Son asabiyya, le lien qui fait tenir un groupe, dont la colonisation applique méthodiquement l'inverse." },
  { v: "Diagnostiquer", d: "La colonisabilité de Bennabi : l'état interne qui a rendu la colonisation possible. Le concept responsabilise le colonisé sans dédouaner le colonisateur." },
  { v: "Reconnaître", d: "La domination symbolique. Fanon à Blida, Bourdieu en Kabylie, Djebar face à la langue : elle se loge dans l'habitus et la honte de soi, au-delà des lois." },
  { v: "Appliquer", d: "La grille au présent. La double absence de Sayad pour penser l'exil ; les mémoires française et algérienne qui regardent 1962 sans y voir la même chose." },
];

// Le programme — six cours, quinze modules.
const cours = [
  { n: "0", t: "Apprendre à lire", mod: "2 modules", d: "Avant les faits, la méthode : qui a le droit de raconter l'Algérie. Puis Ibn Khaldoun, le premier à théoriser comment une société tient — et comment on la défait." },
  { n: "I", t: "La machine coloniale", mod: "2 modules", d: "1830, la prise d'Alger, le séquestre des terres, le code de l'indigénat. L'Algérie devient le laboratoire juridique où s'invente la domination de tout l'empire." },
  { n: "II", t: "Le corps colonisé", mod: "3 modules", d: "Le dévoilement de 1958, le harem photographié, Djebar, la sexualisation de l'homme maghrébin. Comment la colonisation passe par les corps et les images." },
  { n: "III", t: "Penser la résistance", mod: "4 modules", d: "Abd el-Kader bâtit un État, Ibn Badis refonde une identité, Bennabi pose la colonisabilité, Fanon diagnostique l'aliénation. Puis les nationalismes rivaux, avant l'unité de 1954." },
  { n: "IV", t: "La guerre, et après", mod: "3 modules", d: "Sétif 1945 comme matrice, la guerre 1954-1962 gagnée en la perdant, la torture érigée en système. Le coût politique et psychique de la domination, analysé sans pathos." },
  { n: "V", t: "Après l'indépendance", mod: "1 module", d: "1962, et son héritage. Sayad, le migrant ni d'ici ni de là-bas. Les mémoires française et algérienne qui regardent la même date sans y voir la même chose." },
];

// Les outils analytiques que vous emportez — 5 concepts.
const concepts = [
  { c: "Asabiyya", a: "Ibn Khaldoun", y: "1377", d: "Le lien qui fait tenir un groupe — et qui, brisé, le fait tomber. La colonisation applique l'inverse de la Muqaddima : dissoudre le tissu tribal, religieux, foncier." },
  { c: "Cadre décolonial", a: "Ibn Badis", y: "1931", d: "« L'islam ma religion, l'arabe ma langue, l'Algérie ma patrie. » Vingt-trois ans avant le FLN, l'identité nationale refondée par l'école libre et la presse." },
  { c: "Colonisabilité", a: "Malek Bennabi", y: "1949", d: "Déplacer la question : pourquoi est-on devenu colonisable ? Responsabiliser le colonisé sans jamais dédouaner le colonisateur — la renaissance comme travail sur soi." },
  { c: "Sociodiagnostic", a: "Frantz Fanon", y: "1952", d: "La souffrance du colonisé est un fait politique, produit par le système. L'aliénation s'installe dans le corps et le regard : la domination devient intérieure." },
  { c: "Double absence", a: "Abdelmalek Sayad", y: "1999", d: "L'émigré-immigré : absent là-bas, jamais tout à fait présent ici. Un héritage jamais soldé, transmis de génération en génération — le fil qui relie 1962 au présent." },
];

const inclus = [
  "15 modules vidéo commentés",
  "Un carnet de travail intégré (export PDF)",
  "Un quiz à la fin de chaque cours",
  "Accès à vie + mises à jour incluses",
  "Desktop, tablette, mobile",
  "≈ 2 h 30 de contenu dense",
];
---
<Base
  title="L'Algérie a pensé — Formation | L'Autre Récit"
  description="Six cours, 15 modules : colonisation et décolonisation par les penseurs eux-mêmes — d'Ibn Khaldoun à Fanon, d'Ibn Badis à Sayad. Une théorie de la domination, forgée par celles et ceux qui la subissaient."
  image="/formations/algerie.jpg"
>
  <!-- SEO — données structurées Course + Offer (rich results Google) -->
  <script type="application/ld+json" set:html={JSON.stringify({
    "@context": "https://schema.org",
    "@type": "Course",
    "name": "L'Algérie a pensé",
    "description": "Six cours, 15 modules : colonisation et décolonisation par les penseurs eux-mêmes — d'Ibn Khaldoun à Fanon, d'Ibn Badis à Sayad. Une théorie de la domination, forgée par celles et ceux qui la subissaient.",
    "provider": { "@type": "Organization", "name": "L'Autre Récit", "url": "https://lautrerecit.com" },
    "offers": {
      "@type": "Offer",
      "price": "24.99",
      "priceCurrency": "EUR",
      "category": "Paid",
      "availability": "https://schema.org/InStock"
    },
    "hasCourseInstance": {
      "@type": "CourseInstance",
      "courseMode": "online",
      "courseWorkload": "PT2H30M"
    }
  })} />

  <!-- ===== HERO ===== -->
  <div class="fp-top">
    <div class="grain"></div>
    <section class="fp-hero">
      <div class="container">
        <p class="eyebrow">Formation · Maghreb</p>
        <h1 class="fp-h1">L'Algérie a <span class="gold-grad">pensé</span></h1>
        <p class="fp-sub">Colonisation et décolonisation par les penseurs eux-mêmes — d'Ibn Khaldoun à Fanon, d'Ibn Badis à Sayad. Une théorie de la domination, forgée par celles et ceux qui la subissaient.</p>
        <div class="fp-meta">
          <span class="fp-chip">6 cours</span>
          <span class="fp-chip">15 modules</span>
          <span class="fp-chip">≈ 2 h 30</span>
          <span class="fp-chip">Accès à vie</span>
        </div>
        <div class="fp-cta">
          <a class="btn btn-or btn-lg" href={TUNNEL}>Découvrir l'offre <span class="ar">→</span></a>
          <a class="btn btn-ik" href="#programme">Voir le programme</a>
        </div>
      </div>
    </section>
  </div>

  <!-- ===== LE PROPOS ===== -->
  <section class="section fp-propos">
    <div class="container reveal">
      <p class="eyebrow">Le propos</p>
      <h2 class="fp-h2">Une <em class="gold-grad-d">généalogie</em>, pas trois dates.</h2>
      <div class="fp-propos-body">
        <p class="fp-lead">L'Algérie arrive à l'école française par un filtre : trois dates, une guerre, et un grand silence sur le reste.</p>
        <p>Ici, la colonisation et sa défaite se lisent dans les <strong>textes de ceux qui les ont pensées</strong> — juristes, cheikhs, psychiatres, sociologues, écrivains. Une matrice continue de 1830 à 1962, dont l'écho court jusqu'au présent : la diaspora, la mémoire, la langue. On en repart avec une grille qui sert <strong>au-delà</strong> du cas algérien.</p>
      </div>
    </div>
  </section>

  <!-- ===== COMPÉTENCES ===== -->
  <section class="section dark fp-comp">
    <div class="container">
      <p class="eyebrow">Ce que vous saurez faire</p>
      <h2 class="fp-h2 light">Cinq <em class="gold-grad">capacités</em> à la sortie.</h2>
      <p class="fp-comp-intro">Des outils à mobiliser sur l'histoire coloniale comme sur le présent : la diaspora, la mémoire, les discriminations.</p>
      <div class="fp-comp-grid">
        {competences.map((c, i) => (
          <article class="fp-comp-card reveal">
            <div class="fp-comp-n">{String(i + 1).padStart(2, '0')}</div>
            <h3 class="fp-comp-v">{c.v}</h3>
            <p class="fp-comp-d">{c.d}</p>
          </article>
        ))}
      </div>
    </div>
  </section>

  <!-- ===== PROGRAMME ===== -->
  <section class="section fp-prog" id="programme">
    <div class="container">
      <p class="eyebrow">Le programme</p>
      <h2 class="fp-h2">Six cours, <em class="gold-grad-d">quinze modules</em>.</h2>
      <p class="fp-prog-intro">Chaque module dure une dizaine de minutes : une accroche qui renverse, un mécanisme expliqué, un document analysé, une question à emporter. La progression est cumulative, à votre rythme.</p>

      <ol class="fp-prog-list">
        {cours.map((c) => (
          <li class="fp-prog-row reveal">
            <div class="fp-prog-n">{c.n}</div>
            <div class="fp-prog-main">
              <h3 class="fp-prog-t">{c.t}</h3>
              <p class="fp-prog-d">{c.d}</p>
            </div>
            {c.mod && <div class="fp-prog-mod">{c.mod}</div>}
          </li>
        ))}
      </ol>

      <div class="fp-inclus reveal">
        <p class="fp-inclus-h">Inclus dans la formation</p>
        <ul class="fp-inclus-grid">
          {inclus.map((x) => <li><span class="fp-inclus-mk">✓</span>{x}</li>)}
        </ul>
      </div>
    </div>
  </section>

  <!-- ===== CONCEPTS ===== -->
  <section class="section dark fp-concepts">
    <div class="container">
      <p class="eyebrow">Les outils que vous emportez</p>
      <h2 class="fp-h2 light">Cinq <em class="gold-grad">concepts</em>, une grille.</h2>
      <div class="fp-concepts-grid">
        {concepts.map((k) => (
          <article class="fp-concept reveal">
            <div class="fp-concept-top">
              <span class="fp-concept-tag">{k.a}</span>
              <span class="fp-concept-y">{k.y}</span>
            </div>
            <h3 class="fp-concept-c">{k.c}</h3>
            <p class="fp-concept-d">{k.d}</p>
          </article>
        ))}
      </div>
    </div>
  </section>

  <!-- ===== FONDATEUR ===== -->
  <section class="section fp-founder">
    <div class="container fp-founder-in reveal">
      <div class="fp-founder-mark" aria-hidden="true">R</div>
      <div class="fp-founder-body">
        <p class="eyebrow">Le fondateur</p>
        <h2 class="fp-h2">Qui enseigne&nbsp;?</h2>
        <p class="fp-founder-lead"><strong>Rany</strong>, fondateur de L'Autre Récit, titulaire d'un master en science politique.</p>
        <p>En 2023, il fonde <em>L'Autre Récit</em>, plateforme d'analyse critique sur la politique, la sociologie des médias et la décolonisation, suivie aujourd'hui par plus de <strong>16 000 personnes</strong>. Cette formation prolonge ce travail : lire l'Algérie coloniale non par les vainqueurs, mais par les penseurs qui l'ont subie et théorisée.</p>
        <p>Sa ligne, ici comme ailleurs : analyser des structures de domination, pas commémorer. Des <strong>sources primaires et secondaires fact-checkées</strong> — historiens, sociologues, écrivains — et l'accessibilité du récit.</p>
      </div>
    </div>
  </section>

  <!-- ===== CTA FINAL ===== -->
  <section class="section dark fp-final">
    <div class="container reveal">
      <h2 class="fp-final-h">Prêt·e à lire l'Algérie <em class="gold-grad">autrement</em>&nbsp;?</h2>
      <p class="fp-final-sub">Le programme complet, le tarif et l'inscription se trouvent sur la page dédiée. Accès immédiat, à vie.</p>
      <div class="fp-cta">
        <a class="btn btn-or btn-lg" href={TUNNEL}>Voir l'offre complète <span class="ar">→</span></a>
      </div>
    </div>
  </section>
</Base>

<style>
  /* ===== HERO ===== */
  .fp-top { position: relative; background: radial-gradient(120% 90% at 50% -10%, #1A1714 0%, #0E0C0A 55%, #0A0807 100%); color: #fff; overflow: hidden; }
  .fp-top .grain { position: absolute; inset: 0; pointer-events: none; opacity: .05; background-image: url("data:image/svg+xml,%3Csvg viewBox='0 0 256 256' xmlns='http://www.w3.org/2000/svg'%3E%3Cfilter id='n'%3E%3CfeTurbulence type='fractalNoise' baseFrequency='.85' numOctaves='4' stitchTiles='stitch'/%3E%3C/filter%3E%3Crect width='100%25' height='100%25' filter='url(%23n)'/%3E%3C/svg%3E"); }
  .fp-hero { position: relative; z-index: 1; padding-block: clamp(96px, 13vw, 150px) clamp(48px, 7vw, 84px); }
  .fp-hero .eyebrow { color: var(--or3); }
  .fp-h1 { font-family: var(--serif); font-weight: 700; color: #fff; font-size: clamp(38px, 6vw, 82px); line-height: 1; letter-spacing: -0.03em; margin: 14px 0 0; max-width: 15ch; }
  .fp-h1 span { font-style: italic; }
  .fp-sub { font-size: clamp(17px, 1.7vw, 21px); color: rgba(255,255,255,.8); line-height: 1.6; max-width: 60ch; margin: 22px 0 0; font-weight: 300; }
  .fp-meta { display: flex; flex-wrap: wrap; gap: 10px; margin: 30px 0 0; }
  .fp-chip { font-family: var(--mono); font-size: 11.5px; font-weight: 700; letter-spacing: 0.12em; text-transform: uppercase; color: var(--or2); border: 1px solid rgba(212,176,90,.32); border-radius: 100px; padding: 8px 16px; }
  .fp-cta { display: flex; flex-wrap: wrap; gap: 14px; margin-top: 34px; }

  /* ===== titres ===== */
  .fp-h2 { font-family: var(--serif); font-weight: 700; font-size: clamp(28px, 4vw, 52px); letter-spacing: -0.025em; color: var(--ink); margin: 8px 0 0; }
  .fp-h2.light { color: var(--cr); }
  .fp-h2 em { font-style: italic; }

  .reveal { opacity: 0; transform: translateY(22px); transition: opacity .7s cubic-bezier(.22,1,.36,1), transform .7s cubic-bezier(.22,1,.36,1); }
  .reveal.in { opacity: 1; transform: none; }

  /* ===== PROPOS ===== */
  .fp-propos { background: var(--cr); }
  .fp-propos-body { max-width: 64ch; margin: 22px 0 0; }
  .fp-propos-body p { font-size: clamp(16px, 1.4vw, 19px); line-height: 1.7; color: var(--ink2); margin: 0 0 1.1em; }
  .fp-lead { font-family: var(--serif) !important; font-style: italic; font-size: clamp(20px, 2.2vw, 28px) !important; line-height: 1.4 !important; color: var(--ink) !important; }
  .fp-propos-body strong { color: var(--or2); font-weight: 700; }

  /* ===== COMPÉTENCES ===== */
  .fp-comp { background: radial-gradient(120% 100% at 50% 0%, #16120C, #0E0C0A 70%); }
  .fp-comp-intro { max-width: 60ch; color: rgba(255,255,255,.72); font-size: clamp(16px, 1.5vw, 19px); line-height: 1.6; margin: 16px 0 0; font-weight: 300; }
  .fp-comp-grid { display: grid; grid-template-columns: repeat(auto-fit, minmax(250px, 1fr)); gap: 20px; margin-top: 44px; }
  .fp-comp-card { position: relative; background: linear-gradient(160deg, #19140E, #0E0C0A); border: 1px solid rgba(212,176,90,.26); border-radius: 14px; padding: 28px 26px; transition: transform .45s cubic-bezier(.22,1,.36,1), border-color .4s, box-shadow .45s; box-shadow: 0 30px 64px -34px rgba(0,0,0,.85); }
  .fp-comp-card:hover { transform: translateY(-5px); border-color: var(--or2); box-shadow: 0 50px 100px -34px rgba(0,0,0,.9), 0 0 0 1px var(--or2), 0 0 44px -14px rgba(196,162,74,.28); }
  .fp-comp-n { font-family: var(--mono); font-size: 12px; font-weight: 700; letter-spacing: 0.16em; color: var(--or3); }
  .fp-comp-v { font-family: var(--serif); font-weight: 700; font-size: 24px; color: #fff; margin: 12px 0 8px; letter-spacing: -0.01em; }
  .fp-comp-d { font-family: var(--sans); font-weight: 300; font-size: 15px; line-height: 1.6; color: rgba(242,237,228,.74); margin: 0; }

  /* ===== PROGRAMME ===== */
  .fp-prog { background: var(--cr); }
  .fp-prog-intro { max-width: 62ch; color: var(--ink3); font-size: clamp(16px, 1.4vw, 18px); line-height: 1.6; margin: 16px 0 0; }
  .fp-prog-list { list-style: none; margin: 40px 0 0; padding: 0; display: flex; flex-direction: column; gap: 12px; }
  .fp-prog-row { display: grid; grid-template-columns: 64px 1fr auto; gap: 22px; align-items: center; background: linear-gradient(160deg, #fff, var(--cr) 80%); border: 1px solid var(--cr3); border-radius: 12px; padding: 22px 26px; transition: transform .35s cubic-bezier(.22,1,.36,1), border-color .35s, box-shadow .35s; }
  .fp-prog-row:hover { transform: translateY(-3px); border-color: var(--or2); box-shadow: 0 28px 56px -34px rgba(14,12,10,.45); }
  .fp-prog-n { font-family: var(--serif); font-style: italic; font-weight: 900; font-size: 34px; line-height: 1; color: transparent; background: var(--gold); -webkit-background-clip: text; background-clip: text; text-align: center; }
  .fp-prog-t { font-family: var(--serif); font-weight: 700; font-size: clamp(18px, 1.8vw, 22px); color: var(--ink); margin: 0 0 5px; letter-spacing: -0.01em; }
  .fp-prog-d { font-size: 14.5px; line-height: 1.55; color: var(--ink3); margin: 0; max-width: 64ch; }
  .fp-prog-mod { font-family: var(--mono); font-size: 11px; font-weight: 700; letter-spacing: 0.12em; text-transform: uppercase; color: var(--ink3); white-space: nowrap; }

  .fp-inclus { margin-top: 40px; background: var(--ink); border-radius: 14px; padding: 30px 32px; border: 1px solid rgba(212,176,90,.22); }
  .fp-inclus-h { font-family: var(--mono); font-size: 11px; font-weight: 700; letter-spacing: 0.2em; text-transform: uppercase; color: var(--or3); margin: 0 0 18px; }
  .fp-inclus-grid { list-style: none; margin: 0; padding: 0; display: grid; grid-template-columns: repeat(auto-fit, minmax(220px, 1fr)); gap: 14px 26px; }
  .fp-inclus-grid li { display: flex; align-items: center; gap: 12px; color: rgba(242,237,228,.86); font-size: 15px; }
  .fp-inclus-mk { flex: 0 0 auto; width: 22px; height: 22px; border-radius: 50%; background: rgba(196,162,74,.16); color: var(--or3); display: grid; place-items: center; font-size: 12px; font-weight: 700; }

  /* ===== CONCEPTS ===== */
  .fp-concepts { background: radial-gradient(120% 100% at 50% 0%, #16120C, #0E0C0A 70%); }
  .fp-concepts-grid { display: grid; grid-template-columns: repeat(auto-fit, minmax(230px, 1fr)); gap: 18px; margin-top: 40px; }
  .fp-concept { background: linear-gradient(160deg, #19140E, #0E0C0A); border: 1px solid rgba(212,176,90,.22); border-radius: 14px; padding: 24px 24px 22px; transition: transform .4s cubic-bezier(.22,1,.36,1), border-color .4s, box-shadow .4s; box-shadow: 0 28px 60px -34px rgba(0,0,0,.85); }
  .fp-concept:hover { transform: translateY(-4px); border-color: var(--or2); box-shadow: 0 46px 96px -34px rgba(0,0,0,.9), 0 0 0 1px var(--or2); }
  .fp-concept-top { display: flex; align-items: baseline; justify-content: space-between; gap: 10px; }
  .fp-concept-tag { font-family: var(--mono); font-size: 10px; font-weight: 700; letter-spacing: 0.16em; text-transform: uppercase; color: var(--or2); }
  .fp-concept-y { font-family: var(--serif); font-style: italic; font-weight: 700; font-size: 15px; color: var(--or3); }
  .fp-concept-c { font-family: var(--serif); font-weight: 700; font-size: 21px; color: #fff; margin: 12px 0 8px; letter-spacing: -0.01em; }
  .fp-concept-d { font-family: var(--sans); font-weight: 300; font-size: 14px; line-height: 1.6; color: rgba(242,237,228,.72); margin: 0; }

  /* ===== FONDATEUR ===== */
  .fp-founder { background: var(--cr); }
  .fp-founder-in { display: grid; grid-template-columns: 180px 1fr; gap: clamp(28px, 5vw, 64px); align-items: center; }
  .fp-founder-mark { width: 180px; height: 180px; border-radius: 18px; display: grid; place-items: center; font-family: var(--serif); font-style: italic; font-weight: 900; font-size: 92px; color: transparent; background-color: var(--ink); background-image: radial-gradient(120% 120% at 30% 20%, #1F1914, #0E0C0A); border: 1px solid rgba(212,176,90,.4); box-shadow: 0 30px 64px -34px rgba(0,0,0,.6); position: relative; }
  .fp-founder-mark::after { content: "R"; position: absolute; inset: 0; display: grid; place-items: center; background: var(--gold); -webkit-background-clip: text; background-clip: text; color: transparent; }
  .fp-founder-body { max-width: 62ch; }
  .fp-founder-lead { font-family: var(--serif) !important; font-style: italic; font-size: clamp(19px, 2vw, 25px) !important; line-height: 1.4 !important; color: var(--ink) !important; margin: 14px 0 16px !important; }
  .fp-founder-body p { font-size: clamp(15.5px, 1.4vw, 18px); line-height: 1.7; color: var(--ink2); margin: 0 0 1em; }
  .fp-founder-body strong { color: var(--or2); font-weight: 700; }
  .fp-founder-body em { color: var(--or2); }

  /* ===== CTA FINAL ===== */
  .fp-final { background: radial-gradient(130% 100% at 50% 0%, #16110B 0%, #0E0C0A 60%, #080706 100%); text-align: center; }
  .fp-final-h { font-family: var(--serif); font-weight: 700; font-size: clamp(28px, 4.4vw, 56px); color: #fff; letter-spacing: -0.025em; margin: 0; }
  .fp-final-h em { font-style: italic; }
  .fp-final-sub { max-width: 54ch; margin: 18px auto 0; color: rgba(242,237,228,.74); font-size: clamp(16px, 1.5vw, 19px); line-height: 1.6; font-weight: 300; }
  .fp-final .fp-cta { justify-content: center; margin-top: 32px; }

  @media (prefers-reduced-motion: reduce) { .reveal { opacity: 1; transform: none; transition: none; } }
  @media (max-width: 680px) {
    .fp-prog-row { grid-template-columns: 48px 1fr; }
    .fp-prog-mod { grid-column: 2; }
    .fp-founder-in { grid-template-columns: 1fr; text-align: left; }
    .fp-founder-mark { width: 120px; height: 120px; font-size: 62px; }
  }
</style>

<script is:inline>
  (function () {
    var els = document.querySelectorAll('.reveal');
    if (!('IntersectionObserver' in window) || window.matchMedia('(prefers-reduced-motion: reduce)').matches) {
      els.forEach(function (el) { el.classList.add('in'); });
      return;
    }
    var obs = new IntersectionObserver(function (entries) {
      entries.forEach(function (e) { if (e.isIntersecting) { e.target.classList.add('in'); obs.unobserve(e.target); } });
    }, { threshold: 0.14 });
    els.forEach(function (el) { obs.observe(el); });
  })();
</script>
