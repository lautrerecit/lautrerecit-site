---
import Base from '../layouts/Base.astro';
import { formations } from '../data/formations.js';
import { articles } from '../data/articles.js';
import FormationFeature from '../components/FormationFeature.astro';

// Pour l'instant on ne met en avant QUE la formation disponible (les deux autres en réflexion).
const available = formations.filter((f) => f.status === 'available');

// Hero : alternance stricte photo d'auteur → citation fond noir (Sankara inclus).
const cites = [
  { src: '/citations/cit-1.png', alt: 'Citation — Aimé Césaire (photo)' },
  { src: '/citations/cit-2.png', alt: 'Citation — Malcolm X (fond noir)' },
  { src: '/citations/cit-3.png', alt: 'Citation — Antonio Gramsci (photo)' },
  { src: '/citations/cit-4.png', alt: 'Citation — Frantz Fanon (fond noir)' },
  { src: '/citations/cit-5.png', alt: 'Citation — Ibn Badis (photo)' },
  { src: '/citations/cit-6.png', alt: 'Citation — Thomas Sankara (fond noir)' },
];
const marquee = [...cites, ...cites];

const IG = 'https://www.instagram.com/lautrerecit/';

// ===== TÉMOIGNAGES — avis réels de la communauté sur le média (questionnaire, juin 2026).
// Repris du tunnel de vente. Les avis spécifiques à la formation viendront avec ses premiers élèves.
const temoignages = [
  { src: 'Retour communauté', n: 'Rayan',     q: "Une analyse de l'actualité très juste, un regard éveillé dans un vocabulaire prenant. Des récits qui poussent à la réflexion, à l'introspection et à l'action. <strong>Un média alternatif qui doit devenir une référence.</strong>" },
  { src: 'Retour communauté', n: 'Madeleine', q: "Chrétienne de gauche, cette page me nourrit énormément. Des analyses d'une grande finesse, qui décalent le regard et reposent les bonnes questions. <strong>Quelle respiration&nbsp;!</strong>" },
  { src: 'Retour communauté', n: 'Chaïmae',   q: "Un travail de recherche solide, des références sérieuses en sciences humaines. L'Autre Récit <strong>vulgarise le travail scientifique</strong> là où les premiers concernés sont souvent absents du débat." },
  { src: 'Retour communauté', n: 'Soumaya',   q: "Un média pertinent et sourcé, qui mobilise les sciences sociales pour décortiquer l'actualité. <strong>Indépendant, nécessaire et incontournable.</strong>" },
  { src: 'Retour communauté', n: 'Inès',      q: "Enfin un média qui nous instruit réellement et donne de vraies clés de compréhension du monde. <strong>Le média qui nous manquait.</strong>" },
  { src: 'Retour communauté', n: 'Lina',      q: "Une vision plus éclairée de l'actualité, de l'histoire et de la société. J'y retrouve même <strong>les auteurs que j'étudie en cours</strong> — ça m'aide vraiment." },
  { src: 'Retour communauté', n: 'Anonyme',   q: "Les ouvertures à la fin des posts nous poussent à nous remettre en question, à ne plus être seulement des consommateurs. Une très belle façon d'écrire et de synthétiser&nbsp;: vous rendez Instagram <strong>un peu moins superflu</strong>." },
  { src: 'Retour communauté', n: 'Maëva',     q: "Un vent de fraîcheur&nbsp;: enfin un point de vue qui nous ressemble, <strong>basé sur les faits, pas sur l'émotion</strong>." },
  { src: 'Retour communauté', n: 'Insaf',     q: "Explorer des <strong>grilles de lecture alternatives</strong> aux représentations dominantes, et très bien amené. Un compte qui aide à prendre du recul et à voir le monde autrement." },
  { src: 'Retour communauté', n: 'Julie',     q: "Des analyses qualitatives qui citent leurs sources et invitent à la réflexion. <strong>Le seul média qui me permet de me sentir impliquée sans me démoraliser.</strong>" },
  { src: 'Retour communauté', n: 'Anonyme',   q: "Comprendre le monde dans sa complexité, en <strong>croisant sciences sociales et religion</strong>. Une portée qui pousse vraiment à réfléchir." },
  { src: 'Retour communauté', n: 'Anonyme',   q: "Un contenu différent de ce qu'on voit d'habitude, qui pousse à <strong>voir certains sujets sous un autre angle</strong>." },
  { src: 'Retour communauté', n: 'Anonyme',   q: "Une grille d'analyse pour mieux comprendre l'actualité, à travers le prisme des <strong>inégalités sociales, raciales et religieuses</strong>." },
  { src: 'Retour communauté', n: 'Anonyme',   q: "Une rédaction claire, détaillée, sourcée et intelligente. <strong>À lire pour ressortir grandi.</strong>" },
];

// Ordre = grille du profil Instagram (récents en tête), rythme photo / fond noir / photo.
// url = permalien du post exact (fournis par Rany).
const posts = [
  { src: '/posts/post-10.png', cap: "17 octobre 1961 : la police de Paris jette des Algériens dans la Seine. « Ici on noie les Algériens » — puis on noie le souvenir.", url: 'https://www.instagram.com/p/DP4nj0rAuRB/' },
  { src: '/posts/post-11.png', cap: "Consommer est devenu une identité. Comment le marché a fait d'une spiritualité de la sobriété une cible marketing.", url: 'https://www.instagram.com/p/DT8zP4Bgmxr/' },
  { src: '/posts/post-12.png', cap: "« Sauver les femmes » : derrière la formule, un récit occidental qui parle à leur place. Les Iraniennes valent mieux que ça.", url: 'https://www.instagram.com/p/DVo7baiApvW/' },
  { src: '/posts/post-1.png', cap: "Le foot n'a jamais été apolitique — la Coupe du Monde aux États-Unis le rappelle à ceux qui l'avaient oublié.", url: 'https://www.instagram.com/p/DZf26Khguy9/' },
  { src: '/posts/post-2.png', cap: "Le mythe du « self-made » appliqué à Attal : ce que cache le récit du mérite quand on naît déjà du bon côté.", url: 'https://www.instagram.com/p/DZTIuLrAqwL/' },
  { src: '/posts/post-3.png', cap: "Pouvoir dire « arrêtez de tout politiser », c'est déjà un privilège : celui que la politique n'inquiète pas.", url: 'https://www.instagram.com/p/DZGSq6OAmXU/' },
  { src: '/posts/post-4.png', cap: "La vie est une lutte. La vraie question : avec quels outils on s'y arme — ou on la subit.", url: 'https://www.instagram.com/p/DY0EX69Am_b/' },
  { src: '/posts/post-5.png', cap: "8 mai 1945 : pendant qu'on fête la victoire, la France massacre à Sétif, Guelma et Kherrata. L'autre mémoire de cette date.", url: 'https://www.instagram.com/p/DYDSRncAvDs/' },
  { src: '/posts/post-6.png', cap: "Qu'est devenue la communauté du juste milieu et de la modération ? Retour sur un idéal qu'on invoque plus qu'on ne vit.", url: 'https://www.instagram.com/p/DXz3GSjAiEt/' },
  { src: '/posts/post-7.png', cap: "« C'est toujours la faute des Arabes » : anatomie de l'inversion accusatoire, ce réflexe hérité de la grammaire coloniale.", url: 'https://www.instagram.com/p/DXKhfykglYn/' },
  { src: '/posts/post-9.png', cap: "Al-Aqsa sous verrou. La vraie question que ça nous pose : sommes-nous encore dignes de notre héritage ?", url: 'https://www.instagram.com/p/DWSJA-JlGQ4/' },
  { src: '/posts/fastfood.png', cap: "La halalisation des fast-foods : quand la ummā devient une cible marketing.", url: 'https://www.instagram.com/p/DTdxRmCAuhL/?img_index=1' },
];
---
<Base
  title="L'Autre Récit — Média d'analyse critique"
  description="Un média qui déconstruit les récits dominants et rend aux minorités les outils de leur propre histoire — analyses, articles et formations."
>
  <!-- ===== BLOC SOMBRE : HERO + CITATIONS ===== -->
  <div class="top-dark">
    <div class="grain"></div>
    <section class="hero">
      <div class="container">
        <h1 class="hero-h">
          <span class="hh-1">L'Autre&nbsp;Récit</span>
          <span class="hh-2 gold-grad">commence ici.</span>
        </h1>
        <p class="hero-accroche">«&nbsp;Reprendre le contrôle du <em>récit</em>, c'est <em>arracher la plume</em> à ceux qui l'ont confisquée.&nbsp;»</p>
        <p class="hero-lede">
          Le monde ne se donne jamais brut&nbsp;: il est raconté par ceux qui ont le pouvoir
          de le dire. L'Autre Récit s'attaque à ce cadrage — d'où il vient, ce qu'il rend
          invisible, à qui il profite.
        </p>
        <div class="hero-cta">
          <a class="btn btn-or hero-scroll" href="#decouvrir">Entrer dans le récit <span class="ar ar-down">↓</span></a>
        </div>
      </div>
    </section>

    <section class="cites" aria-label="Citations">
      <div class="cite-track">
        {marquee.map((c) => (
          <a class="cite-card" href="/grille-de-lecture/" aria-label="Découvrir la grille de lecture">
            <img src={c.src} alt={c.alt} loading="lazy" width="1080" height="1440" />
          </a>
        ))}
      </div>
    </section>
  </div>

  <!-- ===== LA VISION ===== -->
  <section class="section dark vision" id="decouvrir">
    <div class="container">
      <p class="eyebrow">Le projet</p>
      <h2 class="vision-h">La <span class="gold-grad">vision</span></h2>
      <div class="vision-body reveal">
        <p>Les récits dominants fixent ce qui passe pour normal, vrai, évident — jusque dans la tête de ceux qu'ils visent.</p>
        <p><em>L'Autre Récit</em> reprend ce travail à la racine, avec deux outils&nbsp;: la rigueur de la science politique, et une exigence de responsabilité qui commence par soi.</p>
      </div>
      <a class="btn btn-or" href="/a-propos/">En savoir plus <span class="ar">→</span></a>
    </div>
  </section>

  <!-- ===== FORMATIONS (toutes les disponibles, Algérie en tête) ===== -->
  <section class="section formations">
    <div class="container">
      <p class="eyebrow">Le catalogue</p>
      <h2>Les <em class="gold-grad-d">formations</em></h2>
      <div class="feature-wrap reveal">
        {available.map((f) => (
          <FormationFeature
            title={f.title}
            eyebrow={f.eyebrow}
            blurb={f.blurb}
            href={f.href}
            duration={f.duration}
            status={f.status}
            image={f.image}
          />
        ))}
      </div>
    </div>
  </section>

  <!-- ===== ARTICLES (Substack) · dernier article + lien vers le journal ===== -->
  <section class="section artf">
    <div class="container artf-head">
      <p class="eyebrow">Le journal</p>
      <h2 class="artf-title">Le dernier <em class="gold-grad">article</em></h2>
      <p class="artf-intro">La dernière analyse en date. Retrouvez toutes les autres dans le journal.</p>
    </div>
    <div class="artf-list">
      {articles.slice(0, 1).map((a) => (
        <a class="artf-band reveal" href={a.url} target="_blank" rel="noopener" aria-label={a.t}>
          <div class="artf-ph"><img src={a.cover} alt={a.t} loading="lazy" /></div>
          <div class="artf-tx">
            <div class="artf-meta">{a.cat} · {a.date}</div>
            <h3 class="artf-bh">{a.t}</h3>
            <p class="artf-d">{a.d}</p>
            <span class="artf-lk"><i></i><b>Lire sur Substack</b></span>
          </div>
        </a>
      ))}
    </div>
    <div class="artf-cta">
      <a class="btn btn-or" href="/articles/">Voir tous les articles <span class="ar">→</span></a>
    </div>
  </section>

  <!-- ===== TÉMOIGNAGES (communauté — média) · clôture avant la signature ===== -->
  <section class="section temoignages">
    <div class="container">
      <p class="eyebrow">Les retours</p>
      <h2 class="tm-h">Une communauté <em class="gold-grad-d">engagée</em>.</h2>
      <p class="tm-intro">Des retours d'une communauté engagée — récoltés cette année.</p>
    </div>
    <div class="tm-marquee" aria-label="Témoignages de la communauté">
      <div class="tm-track">
        {[...temoignages, ...temoignages].map((t, i) => (
          <figure class="tm-card" aria-hidden={i >= temoignages.length ? 'true' : undefined}>
            <div class="tm-mark" aria-hidden="true">«</div>
            <blockquote class="tm-q" set:html={t.q}></blockquote>
            <figcaption class="tm-attr">
              <span class="tm-src">{t.src}</span>
              <span class="tm-dot"></span>
              <span class="tm-n">{t.n}</span>
            </figcaption>
          </figure>
        ))}
      </div>
    </div>
  </section>

  <!-- ===== INSTAGRAM ===== -->
  <section class="section insta">
    <div class="container">
      <p class="eyebrow">Instagram</p>
      <h2 class="insta-h">Rejoins-nous sur <em class="gold-grad">Instagram</em></h2>
      <div class="insta-grid reveal">
        {posts.map((p) => (
          <a class="insta-card" href={p.url} target="_blank" rel="noopener" aria-label="Voir le post sur Instagram">
            <div class="insta-img">
              <img src={p.src} alt={p.cap} loading="lazy" width="1080" height="1440" />
              <span class="insta-view"><svg class="ig-ico" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8"><rect x="2.5" y="2.5" width="19" height="19" rx="5.4"/><circle cx="12" cy="12" r="4.2"/><circle cx="17.6" cy="6.4" r="1.2" fill="currentColor" stroke="none"/></svg>Voir le post</span>
            </div>
            <p class="insta-cap">{p.cap}</p>
            <span class="insta-ig">
              <svg class="ig-ico" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8"><rect x="2.5" y="2.5" width="19" height="19" rx="5.4"/><circle cx="12" cy="12" r="4.2"/><circle cx="17.6" cy="6.4" r="1.2" fill="currentColor" stroke="none"/></svg>
              @lautrerecit
            </span>
          </a>
        ))}
      </div>
      <div class="insta-cta">
        <a class="insta-follow" href={IG} target="_blank" rel="noopener">
          <svg class="ig-ico" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.9"><rect x="2.5" y="2.5" width="19" height="19" rx="5.4"/><circle cx="12" cy="12" r="4.2"/><circle cx="17.6" cy="6.4" r="1.2" fill="currentColor" stroke="none"/></svg>
          <span class="if-handle">@lautrerecit</span>
          <span class="if-sep"></span>
          <span class="if-label">Suivre</span>
        </a>
      </div>
    </div>
  </section>

  <!-- ===== NEWSLETTER (Substack) ===== -->
  <section class="section nl">
    <div class="container nl-in reveal">
      <p class="eyebrow">La newsletter</p>
      <h2 class="nl-h">Recevez <em>L'Autre&nbsp;Récit</em></h2>
      <p class="nl-sub">Chaque nouvelle analyse, en avant-première dans votre boîte.</p>
      <form class="nl-form" action="https://autrerecit.substack.com/subscribe" method="get" target="_blank" rel="noopener">
        <input class="nl-input" type="email" name="email" placeholder="votre@email.com" required aria-label="Votre adresse e-mail" />
        <button class="btn btn-or nl-btn" type="submit">S'abonner <span class="ar">→</span></button>
      </form>
      <p class="nl-fine">Un clic pour se désabonner, à tout moment.</p>
    </div>
  </section>

</Base>

<style>
  /* ===== BLOC SOMBRE (hero + citations) ===== */
  .top-dark { position: relative; background: radial-gradient(120% 90% at 50% -10%, #1A1714 0%, #0E0C0A 55%, #0A0807 100%); color: #fff; overflow: hidden; }
  /* halo doré flou sous les cartes — casse l'aplat noir avant la Vision */
  .top-dark::after { content: ""; position: absolute; left: 50%; bottom: -10px; transform: translateX(-50%); width: min(1100px, 94%); height: 320px; background: radial-gradient(ellipse 62% 100% at 50% 100%, rgba(196,162,74,.20), rgba(196,162,74,.07) 45%, transparent 72%); filter: blur(10px); pointer-events: none; z-index: 0; }
  .top-dark .grain { position: absolute; inset: 0; pointer-events: none; opacity: .05; z-index: 0; background-image: url("data:image/svg+xml,%3Csvg viewBox='0 0 256 256' xmlns='http://www.w3.org/2000/svg'%3E%3Cfilter id='n'%3E%3CfeTurbulence type='fractalNoise' baseFrequency='.85' numOctaves='4' stitchTiles='stitch'/%3E%3C/filter%3E%3Crect width='100%25' height='100%25' filter='url(%23n)'/%3E%3C/svg%3E"); }

  .hero { position: relative; z-index: 1; padding-block: clamp(74px, 12vw, 152px) clamp(38px, 6vw, 72px); text-align: center; }
  .hero .eyebrow { color: var(--or3); }
  .hero-h { display: flex; flex-direction: column; align-items: center; margin: 16px 0 0; }
  .hh-1 { font-family: var(--serif); font-weight: 700; color: #fff; font-size: clamp(46px, 8vw, 110px); line-height: .92; letter-spacing: -0.028em; }
  .hh-2 { font-family: var(--serif); font-style: italic; font-weight: 700; font-size: clamp(34px, 5.6vw, 78px); line-height: .96; letter-spacing: -0.02em; margin-top: -0.02em; }
  .hero-accroche { font-family: var(--serif); font-style: normal; font-weight: 400; font-size: clamp(22px, 2.7vw, 36px); line-height: 1.4; color: var(--cr); max-width: 42ch; margin: 26px auto 0; letter-spacing: -0.01em; }
  .hero-accroche em { font-style: italic; color: transparent; background: var(--gold); -webkit-background-clip: text; background-clip: text; }
  .hero-lede { font-size: clamp(16px, 1.7vw, 19px); color: rgba(255,255,255,.74); line-height: 1.6; max-width: 52ch; margin: 18px auto 0; font-weight: 300; }
  .hero-cta { display: flex; flex-wrap: wrap; gap: 14px; justify-content: center; margin-top: 38px; }

  .cites { position: relative; z-index: 1; padding-bottom: clamp(48px, 7vw, 92px); -webkit-mask-image: linear-gradient(90deg, transparent, #000 6%, #000 94%, transparent); mask-image: linear-gradient(90deg, transparent, #000 6%, #000 94%, transparent); }
  .cite-track { display: flex; gap: 20px; width: max-content; animation: citeScroll 32s linear infinite; }
  .cites:hover .cite-track { animation-play-state: paused; }
  @keyframes citeScroll { from { transform: translateX(0); } to { transform: translateX(-50%); } }
  /* Cards citations — survol « glow + scale léger » (effet 10) ; le curseur signale le clic */
  .cite-card { position: relative; display: block; width: 272px; flex-shrink: 0; margin: 0; aspect-ratio: 3 / 4; border-radius: 12px; overflow: hidden; border: 1px solid rgba(212,176,90,.22); box-shadow: 0 28px 54px -28px rgba(0,0,0,.85); cursor: pointer; transition: transform .45s cubic-bezier(.22,1,.36,1), border-color .4s, box-shadow .45s; }
  .cite-card img { width: 100%; height: 100%; object-fit: cover; display: block; }
  .cite-card:hover { transform: scale(1.035); border-color: var(--or2); box-shadow: 0 30px 60px -28px rgba(0,0,0,.85), 0 0 40px -8px rgba(196,162,74,.4); }

  /* ===== VISION ===== */
  .vision { text-align: center; }
  .vision-h { font-family: var(--serif); font-size: clamp(34px, 4.6vw, 62px); color: var(--cr); margin: 8px 0 0; letter-spacing: -0.025em; font-weight: 700; }
  .vision-h .gold-grad { font-style: italic; }
  .vision-body { max-width: 60ch; margin: 20px auto 32px; }
  .vision-body p { color: rgba(255,255,255,.82); font-size: clamp(17px, 1.8vw, 21px); line-height: 1.6; font-weight: 300; margin: 0 auto 1em; }
  .vision-body em { color: var(--or2); }

  /* ===== FORMATION (vedette) ===== */
  .formations h2 em { font-style: italic; }
  .feature-wrap { margin-top: 40px; display: flex; flex-direction: column; gap: clamp(24px, 3.5vw, 44px); }
  .cards { display: grid; grid-template-columns: repeat(auto-fit, minmax(320px, 1fr)); gap: 26px; margin-top: 40px; perspective: 1600px; perspective-origin: 50% 40%; }
  .card { display: flex; flex-direction: column; background: linear-gradient(160deg, #fff 0%, var(--cr) 70%, var(--cr2) 100%); border: 1px solid rgba(154,123,46,.28); border-radius: var(--radius); padding: 32px 30px 26px; color: var(--ink2); overflow: hidden; transform-style: preserve-3d; will-change: transform; box-shadow: 0 28px 60px -28px rgba(14,12,10,.45), inset 0 1px 0 rgba(255,255,255,.5); transition: transform .5s cubic-bezier(.34,1.56,.64,1), box-shadow .45s, border-color .4s; transform: translateZ(0); }
  .card:hover { transform: translateZ(36px) translateY(-6px); box-shadow: 0 56px 110px -28px rgba(14,12,10,.5), 0 0 0 1px var(--or2), 0 0 60px rgba(196,162,74,.3); border-color: var(--or2); z-index: 2; color: var(--ink2); }
  .card.soon { opacity: .92; }
  .card-top { display: flex; align-items: center; justify-content: space-between; gap: 12px; }
  .card-eyebrow { font-family: var(--mono); font-size: 11px; font-weight: 700; letter-spacing: 0.2em; text-transform: uppercase; color: var(--or2); }
  .badge { font-family: var(--mono); font-size: 10px; font-weight: 700; letter-spacing: 0.14em; text-transform: uppercase; padding: 4px 10px; border-radius: 100px; }
  .badge.available { background: var(--ink); color: var(--cr); }
  .badge.soon { background: var(--cr2); color: var(--ink3); border: 1px solid var(--cr3); }
  .card-h { margin-top: 18px; font-size: var(--t-card); }
  .card-blurb { font-size: 15.5px; color: var(--ink3); line-height: 1.65; }
  .card-foot { margin-top: auto; padding-top: 18px; display: flex; align-items: center; justify-content: space-between; font-family: var(--mono); font-size: 12px; font-weight: 700; letter-spacing: 0.12em; text-transform: uppercase; color: var(--ink3); }
  .card-arrow { color: var(--or2); font-size: 18px; }

  /* capture email (cartes à venir) — Netlify Forms */
  .card-form { margin-top: auto; padding-top: 18px; }
  .card-form .hp { position: absolute; left: -9999px; }
  .card-form-label { display: block; font-family: var(--mono); font-size: 10.5px; font-weight: 700; letter-spacing: 0.12em; text-transform: uppercase; color: var(--or2); margin-bottom: 10px; }
  .card-form-row { display: flex; gap: 8px; }
  .card-form input[type="email"] { flex: 1; min-width: 0; padding: 11px 14px; border: 1px solid var(--cr3); border-radius: 8px; background: #fff; font-family: var(--sans); font-size: 14px; color: var(--ink); }
  .card-form input[type="email"]:focus { outline: none; border-color: var(--or2); box-shadow: 0 0 0 3px rgba(196,162,74,.18); }
  .card-form button { flex-shrink: 0; width: 46px; border: none; border-radius: 8px; background: linear-gradient(180deg, var(--or2), var(--or)); color: var(--ink); font-size: 17px; font-weight: 700; cursor: pointer; transition: transform .25s, box-shadow .25s; }
  .card-form button:hover { transform: translateY(-2px); box-shadow: 0 10px 24px -10px rgba(196,162,74,.6); }

  /* ===== INSTAGRAM ===== */
  .insta { background: radial-gradient(120% 120% at 50% 0%, #15110C 0%, #0E0C0A 60%, #0A0807 100%); }
  .insta-h { text-align: center; font-family: var(--serif); font-size: clamp(30px, 4vw, 56px); color: var(--cr); margin: 8px 0 0; letter-spacing: -0.025em; font-weight: 700; }
