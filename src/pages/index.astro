---
import Base from '../layouts/Base.astro';
import { formations } from '../data/formations.js';
---
<Base
  title="L'Autre Récit — Formations d'histoire critique"
  description="Des formations pour déconstruire les récits dominants et redonner aux minorités les outils de leur propre histoire."
>
  <!-- HERO -->
  <section class="hero">
    <div class="container">
      <p class="eyebrow">Histoire critique · Formations en ligne</p>
      <h1 class="hero-h">
        Et si on racontait <em>l'autre récit</em> de l'histoire&nbsp;?
      </h1>
      <p class="lede hero-lede">
        Des formations exigeantes qui rendent aux minorités les outils de leur
        propre histoire — sources, concepts et grilles de lecture, loin des
        clichés et des raccourcis.
      </p>
      <div class="hero-cta">
        <a class="btn btn-gold" href="/formations/">Voir les formations →</a>
        <a class="btn btn-ghost" href="/manifeste/">Lire le manifeste</a>
      </div>
    </div>
  </section>

  <hr class="rule container" />

  <!-- FORMATIONS -->
  <section class="section">
    <div class="container">
      <p class="eyebrow">Le catalogue</p>
      <h2>Les formations</h2>
      <div class="cards">
        {formations.map((f) => (
          <a
            class:list={['card', { soon: f.status === 'soon' }]}
            href={f.status === 'available' ? f.href : undefined}
            aria-disabled={f.status === 'soon'}
          >
            <div class="card-top">
              <span class="card-eyebrow">{f.eyebrow}</span>
              <span class:list={['badge', f.status]}>
                {f.status === 'available' ? 'Disponible' : 'Bientôt'}
              </span>
            </div>
            <h3 class="card-h">{f.title}</h3>
            <p class="card-blurb">{f.blurb}</p>
            <span class="card-foot">
              {f.duration}
              <span class="card-arrow">{f.status === 'available' ? '→' : ''}</span>
            </span>
          </a>
        ))}
      </div>
    </div>
  </section>

  <!-- MANIFESTE TEASER -->
  <section class="section dark teaser">
    <div class="container">
      <p class="eyebrow">Pourquoi L'Autre Récit</p>
      <p class="teaser-q">
        « L'histoire est écrite par les vainqueurs. »
        <span>Ces formations rendent la plume aux autres.</span>
      </p>
      <a class="btn btn-gold" href="/manifeste/">Découvrir la démarche →</a>
    </div>
  </section>
</Base>

<style>
  .hero { padding-block: clamp(64px, 12vw, 150px) clamp(40px, 7vw, 90px); }
  .hero-h { font-size: var(--t-hero); max-width: 16ch; }
  .hero-lede { margin-top: 22px; }
  .hero-cta { display: flex; flex-wrap: wrap; gap: 14px; margin-top: 38px; }

  .cards {
    display: grid; grid-template-columns: repeat(auto-fit, minmax(320px, 1fr));
    gap: 24px; margin-top: 36px;
  }
  .card {
    display: flex; flex-direction: column;
    background: #fff; border: 1px solid var(--cr3); border-radius: var(--radius);
    padding: 30px 30px 26px; color: var(--ink2);
    transition: transform .3s, box-shadow .3s, border-color .3s;
    box-shadow: 0 12px 30px -22px rgba(0,0,0,.4);
  }
  .card:hover { transform: translateY(-4px); border-color: var(--or2); box-shadow: 0 26px 50px -28px rgba(0,0,0,.5); color: var(--ink2); }
  .card.soon { opacity: .72; cursor: default; }
  .card.soon:hover { transform: none; border-color: var(--cr3); box-shadow: 0 12px 30px -22px rgba(0,0,0,.4); }
  .card-top { display: flex; align-items: center; justify-content: space-between; gap: 12px; }
  .card-eyebrow { font-family: var(--mono); font-size: 11px; font-weight: 700; letter-spacing: 0.2em; text-transform: uppercase; color: var(--or2); }
  .badge { font-family: var(--mono); font-size: 10px; font-weight: 700; letter-spacing: 0.14em; text-transform: uppercase; padding: 4px 10px; border-radius: 100px; }
  .badge.available { background: var(--ink); color: var(--cr); }
  .badge.soon { background: var(--cr2); color: var(--ink3); border: 1px solid var(--cr3); }
  .card-h { margin-top: 18px; font-size: var(--t-card); }
  .card-blurb { font-size: 15.5px; color: var(--ink3); line-height: 1.65; }
  .card-foot {
    margin-top: auto; padding-top: 18px; display: flex; align-items: center; justify-content: space-between;
    font-family: var(--mono); font-size: 12px; font-weight: 700; letter-spacing: 0.12em; text-transform: uppercase; color: var(--ink3);
  }
  .card-arrow { color: var(--or2); font-size: 18px; }

  .teaser { text-align: center; }
  .teaser-q {
    font-family: var(--serif); font-style: italic; font-size: clamp(26px, 3.4vw, 42px);
    color: var(--cr); line-height: 1.3; max-width: 24ch; margin: 10px auto 32px;
  }
  .teaser-q span { display: block; color: var(--or3); font-style: normal; font-size: 0.6em; font-family: var(--sans); margin-top: 16px; letter-spacing: 0.01em; }
</style>
