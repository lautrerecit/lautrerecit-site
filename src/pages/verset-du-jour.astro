---
import Base from '../layouts/Base.astro';
import { versets } from '../data/versets.js';
import { citations } from '../data/citations.js';

// ============================================================
// « Le verset du jour » (sobre, auto par date) + tirage de citation (ludique, penseurs).
// Garde-fou : on ne gamifie PAS l'Écriture. Le verset défile par jour ; seules les citations se « tirent ».
// Données : src/data/versets.js · src/data/citations.js
// ============================================================
const v0 = versets[0]; // fallback rendu côté serveur (no-JS / SEO)
const c0 = citations[0];
---
<Base
  title="Le verset du jour — L'Autre Récit"
  description="Un verset par jour, posé et sourcé, et un tirage de citations de penseurs de la décolonisation et des sciences sociales. Le rituel quotidien de L'Autre Récit."
  noVerset={true}
>
  <script type="application/json" id="verses-data" set:html={JSON.stringify(versets)}></script>
  <script type="application/json" id="cites-data" set:html={JSON.stringify(citations)}></script>

  <!-- ===== HERO ===== -->
  <div class="vd-top">
    <div class="grain"></div>
    <section class="vd-hero">
      <div class="container">
        <p class="eyebrow">Rituel quotidien</p>
        <h1 class="vd-h1">Le verset <span class="gold-grad">du jour</span></h1>
        <p class="vd-lede">Chaque matin, une parole posée. Un point fixe avant de relire le monde.</p>
      </div>
    </section>
  </div>

  <!-- ===== VERSET DU JOUR (sobre) ===== -->
  <section class="vd-verse">
    <div class="container">
      <div class="vd-card">
        <p class="vd-theme" id="vdTheme">{v0.theme}</p>
        <p class="vd-kicker">Aujourd'hui</p>
        <p class="vd-ar" id="vdAr" lang="ar" dir="rtl">{v0.ar}</p>
        <p class="vd-fr" id="vdFr" set:html={v0.fr}></p>
        <p class="vd-ref" id="vdRef">{v0.ref}</p>
      </div>
      <p class="vd-note">Un verset par jour — il change chaque matin.</p>
    </div>
  </section>

  <!-- ===== TIRAGE — carte filante (ludique, penseurs) ===== -->
  <section class="section cf-wrap">
    <div class="container">
      <p class="eyebrow">Tirer au sort</p>
      <h2 class="cf-h2">Une <em>carte</em>, une pensée.</h2>
      <p class="cf-intro">Décolonial, sociologie, science politique, pensée noire… Tirez une carte et laissez le hasard décider de ce qui vous accompagnera aujourd'hui.</p>

      <div class="cf-stage">
        <div class="cf-shoot" id="cfShoot">
          <span class="cf-streak" aria-hidden="true"></span>
          <figure class="cf-card" id="cfCard">
            <span class="cf-tag" id="cfTag">{c0.tag}</span>
            <span class="cf-quote" aria-hidden="true">“</span>
            <blockquote class="cf-q" id="cfQ">{c0.q}</blockquote>
            <figcaption class="cf-a" id="cfA">{c0.a}</figcaption>
          </figure>
        </div>
        <button class="btn btn-or cf-draw" id="cfDraw" type="button">Tirer une carte <span class="ar">↯</span></button>
      </div>
    </div>
  </section>
</Base>

<style>
  /* ===== HERO ===== */
  .vd-top { position: relative; overflow: hidden; background: radial-gradient(120% 90% at 50% -10%, #1A1714 0%, #0E0C0A 55%, #0A0807 100%); color: var(--cr); }
  .vd-top .grain { position: absolute; inset: 0; pointer-events: none; opacity: .05; z-index: 0; background-image: url("data:image/svg+xml,%3Csvg viewBox='0 0 256 256' xmlns='http://www.w3.org/2000/svg'%3E%3Cfilter id='n'%3E%3CfeTurbulence type='fractalNoise' baseFrequency='.85' numOctaves='4' stitchTiles='stitch'/%3E%3C/filter%3E%3Crect width='100%25' height='100%25' filter='url(%23n)'/%3E%3C/svg%3E"); }
  .vd-hero { position: relative; z-index: 1; text-align: center; padding-block: clamp(72px, 11vw, 132px) clamp(34px, 5vw, 56px); }
  .vd-hero .eyebrow { color: var(--or3); }
  .vd-h1 { font-family: var(--serif); font-weight: 700; font-size: clamp(44px, 7.5vw, 92px); color: #fff; letter-spacing: -0.028em; line-height: .95; margin: 12px 0 0; }
  .vd-h1 .gold-grad { font-style: italic; }
  .vd-lede { max-width: 46ch; margin: 22px auto 0; color: rgba(242,237,228,.74); font-weight: 300; font-size: clamp(16px, 1.7vw, 19px); line-height: 1.6; }

  /* ===== VERSET (sobre, dans la continuité du hero sombre) ===== */
  .vd-verse { position: relative; background: linear-gradient(180deg, #0A0807 0%, #0E0C0A 100%); color: var(--cr); padding-block: clamp(20px, 4vw, 40px) clamp(64px, 9vw, 110px); text-align: center; }
  .vd-card { position: relative; max-width: 780px; margin: 0 auto; padding: clamp(34px, 5vw, 60px) clamp(24px, 4vw, 56px); border-radius: 16px; background: radial-gradient(130% 130% at 50% 30%, #16110B 0%, #0E0C0A 72%); border: 1px solid; border-image: linear-gradient(180deg, rgba(196,162,74,.55), rgba(196,162,74,.12) 60%, transparent) 1; box-shadow: 0 50px 110px -50px rgba(0,0,0,.9), inset 0 1px 0 rgba(255,255,255,.04); }
  .vd-card::before { content: ""; position: absolute; left: 50%; top: 42%; width: 640px; height: 300px; max-width: 90%; transform: translate(-50%,-50%); background: radial-gradient(circle, rgba(196,162,74,.09), transparent 68%); pointer-events: none; }
  .vd-theme { position: relative; display: inline-block; font-family: var(--mono); font-size: 10.5px; font-weight: 700; letter-spacing: 0.18em; text-transform: uppercase; color: var(--ink); background: var(--gold); padding: 5px 13px; border-radius: 100px; margin: 0 auto 20px; max-width: none; }
  .vd-kicker { position: relative; font-family: var(--mono); font-size: 10.5px; font-weight: 700; letter-spacing: 0.3em; text-transform: uppercase; color: var(--or3); margin: 0 auto 22px; max-width: none; }
  .vd-ar { position: relative; font-family: 'Amiri', 'Times New Roman', serif; font-weight: 400; font-size: clamp(25px, 3.8vw, 46px); line-height: 1.62; color: #F6F1E8; margin: 0 auto; max-width: 94%; direction: rtl; text-shadow: 0 0 34px rgba(255,255,255,.10); }
  .vd-fr { position: relative; font-family: var(--serif); font-style: normal; font-weight: 400; font-size: clamp(17px, 2vw, 24px); line-height: 1.5; color: rgba(242,237,228,.9); max-width: 56ch; margin: 24px auto 0; }
  .vd-fr :global(em) { font-style: italic; color: transparent; background: var(--gold); -webkit-background-clip: text; background-clip: text; }
  .vd-ref { position: relative; font-family: var(--mono); font-size: 11px; font-weight: 700; letter-spacing: 0.22em; text-transform: uppercase; color: var(--or2); margin: 26px auto 0; max-width: none; }
  .vd-note { text-align: center; font-family: var(--mono); font-size: 11px; letter-spacing: 0.08em; color: rgba(242,237,228,.42); margin: 26px auto 0; max-width: none; }

  /* ===== TIRAGE — carte filante (crème, carte encre & or) ===== */
  .cf-wrap { background: var(--cr); text-align: center; }
  .cf-h2 { font-family: var(--serif); font-weight: 700; font-size: clamp(28px, 4vw, 50px); color: var(--ink); letter-spacing: -0.02em; margin: 8px 0 0; }
  .cf-h2 em { font-style: italic; }
  .cf-intro { color: var(--ink3); font-size: clamp(15px, 1.5vw, 17.5px); line-height: 1.7; max-width: 54ch; margin: 16px auto 0; }

  .cf-stage { margin-top: clamp(38px, 5vw, 56px); display: flex; flex-direction: column; align-items: center; gap: 34px; }
  .cf-shoot { position: relative; width: min(560px, 100%); }
  .cf-streak { position: absolute; left: 50%; top: 50%; width: 150%; height: 2px; transform: translate(-50%,-50%) rotate(26deg); background: linear-gradient(90deg, transparent, rgba(246,222,148,.9) 45%, #fff 50%, rgba(246,222,148,.9) 55%, transparent); opacity: 0; filter: blur(.4px); pointer-events: none; z-index: 3; border-radius: 2px; }

  .cf-card { position: relative; z-index: 2; margin: 0; padding: clamp(30px, 4vw, 46px) clamp(26px, 4vw, 44px) clamp(26px, 3.5vw, 38px); text-align: left; border-radius: 16px; background: linear-gradient(158deg, #1C160F 0%, #12100B 60%, #0C0A07 100%); border: 1px solid rgba(196,162,74,.4); border-top: 2px solid var(--or2); box-shadow: 0 44px 90px -44px rgba(0,0,0,.85); overflow: hidden; }
  .cf-card::after { content: ""; position: absolute; inset: 0; border-radius: 16px; pointer-events: none; background: radial-gradient(120% 80% at 80% -10%, rgba(196,162,74,.14), transparent 60%); }
  .cf-tag { display: inline-block; font-family: var(--mono); font-size: 10.5px; font-weight: 700; letter-spacing: 0.2em; text-transform: uppercase; color: var(--ink); background: var(--gold); padding: 5px 12px; border-radius: 100px; }
  .cf-quote { position: absolute; right: 22px; top: 6px; font-family: var(--serif); font-style: italic; font-weight: 900; font-size: 120px; line-height: 1; color: transparent; background: var(--gold); -webkit-background-clip: text; background-clip: text; opacity: .16; pointer-events: none; }
  .cf-q { font-family: var(--serif); font-style: normal; font-weight: 400; font-size: clamp(20px, 2.6vw, 30px); line-height: 1.42; color: #F6F1E8; margin: 22px 0 0; max-width: 40ch; }
  .cf-a { margin: 22px 0 0; padding-top: 16px; border-top: 1px solid rgba(212,176,90,.2); font-family: var(--mono); font-size: 12px; font-weight: 700; letter-spacing: 0.14em; text-transform: uppercase; color: var(--or2); }

  .cf-draw .ar { font-size: 17px; }

  /* animation « carte filante » — rejouée à chaque tirage via la classe .fly sur .cf-shoot */
  .cf-shoot.fly .cf-card { animation: cfFly .72s var(--ease); }
  .cf-shoot.fly .cf-streak { animation: cfStreak .6s ease-out; }
  @keyframes cfFly {
    0%   { opacity: 0; transform: translate(-42px, -62px) rotate(-7deg) scale(.95); filter: blur(5px); }
    55%  { filter: blur(0); }
    100% { opacity: 1; transform: none; filter: blur(0); }
  }
  @keyframes cfStreak {
    0%   { opacity: 0; transform: translate(-130%, -130%) rotate(26deg); }
    28%  { opacity: .95; }
    100% { opacity: 0; transform: translate(60%, 60%) rotate(26deg); }
  }
  @media (prefers-reduced-motion: reduce) { .cf-shoot.fly .cf-card, .cf-shoot.fly .cf-streak { animation: none; } }
</style>

<script is:inline>
  (function () {
    // ---- Verset du jour : déterministe par jour de l'année (change chaque matin, sans serveur) ----
    var verses = JSON.parse(document.getElementById('verses-data').textContent);
    var now = new Date();
    var start = new Date(now.getFullYear(), 0, 0);
    var day = Math.floor((now - start) / 86400000);
    var v = verses[day % verses.length];
    var ar = document.getElementById('vdAr'), fr = document.getElementById('vdFr'),
        ref = document.getElementById('vdRef'), theme = document.getElementById('vdTheme');
    if (ar && v) { ar.textContent = v.ar; fr.innerHTML = v.fr; ref.textContent = v.ref; if (theme) theme.textContent = v.theme; }

    // ---- Tirage de citation : carte filante (registre profane uniquement) ----
    var cites = JSON.parse(document.getElementById('cites-data').textContent);
    var shoot = document.getElementById('cfShoot');
    var elQ = document.getElementById('cfQ'), elA = document.getElementById('cfA'), elTag = document.getElementById('cfTag');
    var last = -1;
    function draw() {
      var i = Math.floor(Math.random() * cites.length);
      if (cites.length > 1 && i === last) { i = (i + 1) % cites.length; }
      last = i;
      var c = cites[i];
      elQ.textContent = c.q; elA.textContent = c.a; elTag.textContent = c.tag;
      shoot.classList.remove('fly'); void shoot.offsetWidth; shoot.classList.add('fly');
    }
    var btn = document.getElementById('cfDraw');
    if (btn) btn.addEventListener('click', draw);
  })();
</script>
